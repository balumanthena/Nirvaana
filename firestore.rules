rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Blog Collection Rules
    match /blogs/{blogId} {
      // Allow read access for published blogs to everyone
      allow read: if resource.data.status == 'published';
      
      // Allow read access for all blogs (including drafts) to authenticated admins
      allow read: if request.auth != null;
      
      // Allow write access (create, update, delete) only to authenticated admins
      allow write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
